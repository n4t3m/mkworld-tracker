# Example configuration for MKWorld Tracker.
#
# You do NOT need to edit or copy this file manually. The Settings tab in
# the app will create and populate `.env` for you when you save your API
# key or change the model. This file exists only as a reference for the
# variables the app reads.
#
# To use it manually anyway: copy to `.env` in the project root and fill
# in your values. `.env` is gitignored.

# Your Google AI Studio API key. Grab one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Gemini model to use. Suggested values:
#   gemma-4-31b-it              (default; best general-purpose pick)
#   gemma-3-27b-it              (lighter-weight alternative)
#   gemini-3.1-flash-lite-preview  (best when available; rate-limited at peak)
GEMINI_MODEL=gemma-4-31b-it

# Debug mode toggles additional per-race logging. Accepts true/false
# (also 1/0, yes/no, on/off). Toggle from the Settings tab in the app.
DEBUG_MODE=false
